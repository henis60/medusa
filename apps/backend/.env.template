STORE_CORS=http://localhost:8000,https://docs.medusajs.com
ADMIN_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
AUTH_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
REDIS_URL=redis://localhost:6379
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret
DATABASE_URL=
DB_NAME=medusa-backend

# --- PlatiOnline payment provider ---
PO_LOGIN=
PO_WEBSITE=
# RSA keys in PEM. Newlines may be escaped as \n on a single line.
PO_PUBLIC_KEY=
PO_PRIVATE_KEY=
# AES initialization vectors (16 characters each), from the merchant panel.
PO_IV_AUTH=
PO_IV_ITSN=
# Storefront return URL after payment.
PO_RELAY_URL=http://localhost:8000/ro/checkout/plati-online/return
PO_RELAY_METHOD=PTOR
# Gateway base URL (defaults to https://secure.plationline.ro).
PO_BASE_URL=https://secure.plationline.ro
PO_TEST_MODE=true
# Provider id as registered by Medusa (pp_{identifier}_{config-id}).
PO_PROVIDER_ID=pp_plati-online_plati-online
